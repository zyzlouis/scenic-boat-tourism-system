/* pages/boat-type/boat-type.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 140rpx;
}

.loading-container {
  padding: 200rpx 0;
  text-align: center;
}

.boat-detail {
  padding: 24rpx;
}

/* 图片区域 */
.boat-image-wrapper {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  background-color: #f0f0f0;
}

.boat-image {
  width: 100%;
  height: 100%;
}

.boat-image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
}

/* 信息卡片 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.boat-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.boat-capacity {
  font-size: 28rpx;
  color: #1989fa;
  margin-bottom: 16rpx;
}

.boat-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 价格区域 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.price-list {
  margin-top: 24rpx;
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.price-item:last-child {
  border-bottom: none;
}

.price-item .label {
  font-size: 28rpx;
  color: #666;
}

.price-item .value {
  font-size: 28rpx;
  color: #333;
}

.price-item .value.price {
  font-size: 36rpx;
  font-weight: bold;
  color: #1989fa;
}

.price-summary {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.summary-text {
  font-size: 24rpx;
  color: #999;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.book-btn {
  width: 100%;
}
