<!--pages/index/index.wxml-->
<view class="container">
  <!-- 轮播图 -->
  <view wx:if="{{banners.length > 0}}" class="swiper-section">
    <swiper
      class="swiper-container"
      autoplay="{{true}}"
      interval="{{3000}}"
      duration="{{500}}"
      circular="{{true}}"
      indicator-dots="{{true}}"
      indicator-color="rgba(255, 255, 255, 0.5)"
      indicator-active-color="#ffffff"
    >
      <swiper-item wx:for="{{banners}}" wx:key="_id">
        <image
          class="swiper-image"
          src="{{item.imageUrl}}"
          mode="aspectFill"
          bindtap="onBannerClick"
          data-item="{{item}}"
        />
      </swiper-item>
    </swiper>
  </view>

  <!-- 导航宫格 -->
  <view class="nav-section">
    <view class="nav-grid {{navClass}}">
      <view
        wx:for="{{navItems}}"
        wx:key="_id"
        class="nav-item"
        data-path="{{item.pagePath}}"
        bindtap="onNavTap"
      >
        <view class="nav-icon-wrap">
          <image wx:if="{{item.iconUrl}}" class="nav-icon" src="{{item.iconUrl}}" mode="aspectFit" />
          <view wx:else class="nav-icon-placeholder">{{item.name[0]}}</view>
        </view>
        <text class="nav-label">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 活动横幅 -->
  <view wx:if="{{appConfig.promoBannerEnabled && appConfig.promoBannerUrl}}" class="promo-section" bindtap="onPromoBannerTap">
    <image class="promo-banner" src="{{appConfig.promoBannerUrl}}" mode="aspectFill" />
  </view>

  <!-- 公告栏 -->
  <view wx:if="{{announcements.length > 0}}" class="notice-section">
    <view
      class="notice-bar notice-{{announcements[0].type}}"
      bindtap="onAnnouncementClick"
      data-item="{{announcements[0]}}"
    >
      <view class="notice-icon">
        <text wx:if="{{announcements[0].type === 'warning'}}">⚠️</text>
        <text wx:elif="{{announcements[0].type === 'urgent'}}">🚨</text>
        <text wx:else>ℹ️</text>
      </view>
      <view class="notice-content">
        <text class="notice-text">{{announcements[0].title}}</text>
      </view>
      <view class="notice-arrow">
        <van-icon name="arrow" size="16rpx" />
      </view>
    </view>
  </view>

  <!-- 图文推荐 -->
  <view wx:if="{{appConfig.recommendEnabled && recommendItems.length > 0}}" class="recommend-section">
    <view class="recommend-header">
      <text class="recommend-title">{{appConfig.recommendTitle || '精选推荐'}}</text>
    </view>
    <view class="recommend-grid">
      <view
        wx:for="{{recommendItems}}"
        wx:key="_id"
        class="recommend-card"
        data-url="{{item.linkUrl}}"
        bindtap="onRecommendTap"
      >
        <image wx:if="{{item.imageUrl}}" class="recommend-image" src="{{item.imageUrl}}" mode="aspectFill" />
        <view class="recommend-info">
          <text class="recommend-name">{{item.title}}</text>
          <text wx:if="{{item.description}}" class="recommend-desc">{{item.description}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 景区信息卡片 -->
  <view wx:if="{{appConfig}}" class="info-section">
    <view class="info-card">
      <view class="info-card-title">{{appConfig.scenicName || '翠屏湖景区'}}</view>
      <view wx:if="{{appConfig.openTime}}" class="info-item">
        <text class="info-icon">🕐</text>
        <text>营业时间：{{appConfig.openTime}} - {{appConfig.closeTime}}</text>
      </view>
      <view wx:if="{{appConfig.contactPhone}}" class="info-item">
        <text class="info-icon">📞</text>
        <text>联系电话：{{appConfig.contactPhone}}</text>
      </view>
      <view wx:if="{{appConfig.aboutUs}}" class="info-about">{{appConfig.aboutUs}}</view>
    </view>
  </view>
</view>
