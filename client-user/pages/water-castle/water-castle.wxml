<view class="container">
  <van-loading wx:if="{{loading}}" size="48rpx" type="spinner" color="#1989fa" custom-class="loading">加载中...</van-loading>

  <block wx:if="{{!loading && project}}">
    <!-- 项目头部 -->
    <view class="project-header">
      <image wx:if="{{project.imageUrl}}" class="project-banner" src="{{project.imageUrl}}" mode="aspectFill" />
      <view class="project-name">{{project.name}}</view>
      <view class="project-desc">{{project.description}}</view>
      <view wx:if="{{project.openTime}}" class="project-time">营业时间：{{project.openTime}} - {{project.closeTime}}</view>
    </view>

    <!-- 商品列表 -->
    <view class="product-section">
      <view class="product-list">
        <view
          wx:for="{{products}}"
          wx:key="_id"
          class="product-card"
          data-id="{{item._id}}"
          bindtap="goToProductDetail"
        >
          <image wx:if="{{item.imageUrl}}" class="product-image" src="{{item.imageUrl}}" mode="aspectFill" />
          <view class="product-info-card">
            <view class="product-name">{{item.name}}</view>
            <view class="product-desc">{{item.description}}</view>
            <view class="product-bottom">
              <view class="product-price">¥{{item.price}}</view>
              <view wx:if="{{item.stock > 0}}" class="product-stock">剩余{{item.stock - item.soldCount}}份</view>
            </view>
            <view wx:if="{{item.needVerification}}" class="product-tag">需核销 · {{item.verificationDays}}天有效</view>
            <view wx:else class="product-tag no-verify">购买即完成</view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <van-empty wx:if="{{!loading && !project}}" description="暂无项目信息" />
</view>
