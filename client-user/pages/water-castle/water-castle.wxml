<view class="container">
  <!-- 顶部欢迎区域 -->
  <view class="header">
    <view class="title">{{project.name || '水上城堡'}}</view>
    <view class="subtitle">{{project.description || ''}}</view>
    <view wx:if="{{project.openTime}}" class="subtitle">营业时间：{{project.openTime}} - {{project.closeTime}}</view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-container">
    <van-loading size="48rpx" type="spinner" color="#1989fa">加载中...</van-loading>
  </view>

  <!-- 商品列表 -->
  <view wx:else class="product-list">
    <view
      wx:for="{{products}}"
      wx:key="_id"
      class="product-card"
      data-id="{{item._id}}"
      bindtap="goToProductDetail"
    >
      <!-- 商品图片 -->
      <view class="product-image">
        <image
          src="{{item.imageUrl || '/images/boat-placeholder.png'}}"
          mode="aspectFill"
        />
      </view>

      <!-- 商品信息 -->
      <view class="product-info">
        <view class="product-name">{{item.name}}</view>
        <view class="product-desc">{{item.description}}</view>

        <!-- 价格信息 -->
        <view class="price-info">
          <view class="price-row">
            <text class="label">价格：</text>
            <text class="price">¥{{item.price}}</text>
          </view>
          <view wx:if="{{item.needVerification}}" class="price-row">
            <text class="label">核销有效期：</text>
            <text>{{item.verificationDays}}天</text>
          </view>
          <view wx:if="{{item.stock > 0}}" class="price-row">
            <text class="label">剩余库存：</text>
            <text>{{item.stock - item.soldCount}}份</text>
          </view>
          <view wx:if="{{!item.needVerification}}" class="price-row">
            <text class="label">类型：</text>
            <text>购买即完成</text>
          </view>
        </view>

        <!-- 购买按钮 -->
        <view class="product-action">
          <van-button
            type="primary"
            size="large"
            round
            custom-class="buy-button"
          >
            立即购买
          </van-button>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{!loading && products.length === 0}}" class="empty-container">
    <van-empty description="暂无商品" />
  </view>
</view>
