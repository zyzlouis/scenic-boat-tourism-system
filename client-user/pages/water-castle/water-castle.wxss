.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 0;
}

.loading {
  padding: 200rpx 0;
  text-align: center;
}

/* 项目头部 */
.project-header {
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
  color: #ffffff;
}

.project-banner {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.project-name {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.project-desc {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 8rpx;
}

.project-time {
  font-size: 26rpx;
  opacity: 0.7;
}

/* 商品列表 */
.product-section {
  padding: 0 20rpx 20rpx;
}

.product-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.product-card {
  width: 48%;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}

.product-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.product-image {
  width: 100%;
  height: 240rpx;
  background: #f5f5f5;
}

.product-info-card {
  padding: 20rpx;
}

.product-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.product-desc {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.product-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4444;
}

.product-stock {
  font-size: 22rpx;
  color: #999;
}

.product-tag {
  font-size: 20rpx;
  color: #1890ff;
  background: #e6f7ff;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  display: inline-block;
}

.product-tag.no-verify {
  color: #52c41a;
  background: #f6ffed;
}
